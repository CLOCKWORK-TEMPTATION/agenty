DATABASE_URL=postgres://postgres:postgres@localhost:5432/agents
REDIS_URL=redis://localhost:6379
LITELLM_API_BASE=http://localhost:4001
LITELLM_MASTER_KEY=replace_me
LANGSMITH_API_KEY=replace_me
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GOOGLE_API_KEY=replace_me
TAVILY_API_KEY=replace_me
E2B_API_KEY=replace_me
SLACK_BOT_TOKEN=replace_me
GITHUB_TOKEN=replace_me
API_PORT=4000
WEB_PORT=3000
NODE_ENV=development

# Semantic Cache Configuration
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_MAX_SIZE=10000
SEMANTIC_CACHE_HOT_CACHE_SIZE=1000
SEMANTIC_CACHE_ENABLE_AUTO_CLEANUP=true
SEMANTIC_CACHE_CLEANUP_INTERVAL_MS=300000
EMBEDDING_SERVICE_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-ada-002
