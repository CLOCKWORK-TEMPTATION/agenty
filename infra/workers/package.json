{
  "name": "@repo/workers",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/types": "workspace:*",
    "bullmq": "^5.36.6",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
