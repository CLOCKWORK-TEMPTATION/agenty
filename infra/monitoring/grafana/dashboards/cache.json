{
  "title": "Cache Dashboard",
  "uid": "cache",
  "tags": ["cache", "performance"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "cache_hit_rate",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.7, "color": "green" }
            ]
          },
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 2,
      "title": "Cache Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{operation=\"hit\"}[5m]))",
          "legendFormat": "Hits"
        },
        {
          "expr": "sum(rate(cache_operations_total{operation=\"miss\"}[5m]))",
          "legendFormat": "Misses"
        },
        {
          "expr": "sum(rate(cache_operations_total{operation=\"set\"}[5m]))",
          "legendFormat": "Sets"
        },
        {
          "expr": "sum(rate(cache_operations_total{operation=\"delete\"}[5m]))",
          "legendFormat": "Deletes"
        }
      ]
    },
    {
      "id": 3,
      "title": "Hit Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(cache_operations_total{operation=\"hit\"}[5m])) / sum(rate(cache_operations_total{operation=~\"hit|miss\"}[5m]))",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    }
  ]
}
