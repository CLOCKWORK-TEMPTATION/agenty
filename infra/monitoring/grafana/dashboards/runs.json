{
  "title": "Agent Runs Dashboard",
  "uid": "agent-runs",
  "tags": ["runs", "agents"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Run Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(run_status_total{status=\"completed\"}[5m])) / sum(rate(run_status_total[5m]))",
          "legendFormat": "Success Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.9, "color": "yellow" },
              { "value": 0.95, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Run Duration (P95)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(run_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Runs",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(run_status_total{status=\"running\"})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "Revision Loops",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(run_status_total{status=\"max_revisions_reached\"}[5m]))",
          "legendFormat": "Max Reached"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 5,
      "title": "Runs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(run_status_total{status=\"completed\"}[5m]))",
          "legendFormat": "Completed"
        },
        {
          "expr": "sum(rate(run_status_total{status=\"failed\"}[5m]))",
          "legendFormat": "Failed"
        },
        {
          "expr": "sum(rate(run_status_total{status=\"cancelled\"}[5m]))",
          "legendFormat": "Cancelled"
        }
      ]
    }
  ]
}
