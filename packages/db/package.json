{
  "name": "@repo/db",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "migrate": "pnpm run build && node dist/migrate.js",
    "seed": "pnpm run build && node dist/seed.js"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "bullmq": "^5.70.1",
    "ioredis": "^5.9.3",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  }
}
